# ── Supabase ────────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Anon/service key from Supabase dashboard → Settings → API
SUPABASE_KEY=

# PostgreSQL connection string for SQLAlchemy (Chainlit persistence layer).
# Format: postgresql://user:password@host:5432/dbname
# For async (asyncpg): use postgresql+asyncpg://... — app will auto-convert if missing.
SUPABASE_DB_URI=postgresql://postgres:<password>@db.xxxxxxxxxxxx.supabase.co:5432/postgres
# Optional: explicit async URI. If omitted, SUPABASE_DB_URI is converted automatically.
SUPABASE_DB_URI_ASYNC=

# ── OpenRouter (primary AI gateway) ────────────────────────────────────────────
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── OpenAI (fallback if OpenRouter key is absent) ──────────────────────────────
OPENAI_API_KEY=

# ── Apify (web scraping — TikTok, YouTube, Twitter, Instagram) ─────────────────
# Get from https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Chainlit auth ───────────────────────────────────────────────────────────────
# REQUIRED — without this, Chainlit will refuse to start when password auth is enabled.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=

# ── HERALD user credentials ─────────────────────────────────────────────────────
# Dom's login password
HERALD_DOM_PASSWORD=
# Dom's email (used as alternate login identifier)
HERALD_DOM_EMAIL=dom@herald.local
# Admin (Lubosi) login password
HERALD_ADMIN_PASSWORD=
# Admin email (used as alternate login identifier)
HERALD_ADMIN_EMAIL=lubosi@herald.local

# ── Telegram bot (newsletter approval gate) ─────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Telegram chat ID that is allowed to receive/approve newsletter drafts
TELEGRAM_ALLOWED_CHAT_ID=

# ── DataForSEO (optional — SEO research tool) ──────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Base64-encoded "login:password" — auto-computed from the above if left blank
DATAFORSEO_AUTH_B64=

# ── xAI Grok (X/Twitter intelligence sweeps) ───────────────────────────────────
# Get from https://console.x.ai
GROK_API_KEY=

# ── Hermes (local reasoning model — optional CLI fallback) ──────────────────────
# Command name if a local model binary is installed (e.g. "hermes", "ollama")
HERMES_COMMAND=hermes
# Max seconds to wait for a Hermes/local model response
HERMES_TIMEOUT_SECONDS=900

# ── Misc ────────────────────────────────────────────────────────────────────────
# Override the default chat model key (matches AVAILABLE_MODELS in app.py)
HERALD_CHAT_MODEL=openai/gpt-4o
# Override the default model key for new sessions (matches AVAILABLE_MODELS key in app.py)
HERALD_DEFAULT_MODEL=gpt-4o
# Set to "true" to route AI calls through legacy local model instead of OpenRouter
HERALD_USE_LEGACY_AI=false
# Python interpreter override (defaults to python3)
PYTHON=python3
